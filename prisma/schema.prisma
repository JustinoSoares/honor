// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model user {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  phone        String
  password     String
  role         role      @default(USER)
  verified     Boolean   @default(false)
  reset_code   String?
  reset_expire DateTime?
  events       event[]
  members      member[]
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
}

model event {
  id           String    @id @default(uuid())
  title        String
  category     String
  description  String
  date_start   DateTime
  date_end     DateTime?
  promoter     String // quem está a realizar o evento ou o nome da empresa
  promoter_nif String // nif do promotor
  duration     Int? // duração do evento em minutos
  contact      Json // contato para mais informações ["example@example.com", "123456789"]
  location     String
  province     String
  available    Boolean   @default(false)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  classification String? // A, B, C
  responsible_id String? // O nosso funcionario responsável por este evento
  responsible    user?           @relation(fields: [responsible_id], references: [id])
  event_category event_category? @relation(fields: [category], references: [name])
  images         image[]
  guests         guest[]
  packages       packages[]
  members        member[]
}

model member {
  id         String     @id @default(uuid())
  user_id    String
  event_id   String
  name       String // nome do membro, para facilitar a identificação, por exemplo: João Silva
  user       user       @relation(fields: [user_id], references: [id])
  event      event      @relation(fields: [event_id], references: [id])
  permission permission @default(STAFF) // cargo do membro no evento, por exemplo: organizador, voluntário, etc.
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt
}

// adiconar categorias para os eventos, como por exemplo: música, teatro, conferência, etc. para facilitar a organização e busca dos eventos
model event_category {
  id         String   @id @default(uuid())
  name       String   @unique
  active     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  events event[]
}

model packages {
  id          String       @id @default(uuid())
  name        String
  description String
  price       Float
  event_id    String
  priority    Int          @default(0)
  event       event        @relation(fields: [event_id], references: [id])
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  invitations invitation[]
}

model image {
  id         String   @id @default(uuid())
  url        String
  priority   Int      @default(0)
  event_id   String
  event      event    @relation(fields: [event_id], references: [id])
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model invitation {
  id          String   @id @default(uuid())
  packages_id String
  guest_id    String
  qr_code     String?
  is_used     Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  package packages @relation(fields: [packages_id], references: [id])
  guest   guest    @relation(fields: [guest_id], references: [id])
}

model guest {
  id               String       @id @default(uuid())
  name             String
  email            String
  phone            String
  code_email       String? // código de confirmação para o evento
  expiration_email DateTime? // data de expiração do código de confirmação
  status           status_guest @default(PENDING)
  link             String?
  is_paid          Boolean      @default(false)
  event_id         String
  event            event        @relation(fields: [event_id], references: [id])
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt
  invitations      invitation[]
}

enum role {
  USER
  MANAGER
  ADMIN
}

enum status_guest {
  PENDING // fez a solicitacao
  CONFIRMED // pagou o evento e recebeu o convite
  COMPLETED // participou do evento, recebeu a fita
  CANCELLED // cancelou a participação
  BLOCKED // bloqueado por algum motivo, não pode participar do evento
}

enum permission {
  MANAGER
  STAFF
}
