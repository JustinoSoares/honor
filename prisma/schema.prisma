// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model user {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  phone         String?
  password      String
  refreshToken  String? // token para manter o usuário logado
  role          role           @default(USER)
  verified      Boolean        @default(false)
  reset_code    String?
  reset_expire  DateTime?
  events        event[]
  members       member[]
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  tickets       ticket[]
  notifications notification[]
  comments      comment[]
}

model event {
  id               String          @id @default(uuid())
  title            String
  category         String
  description      String
  date_start       DateTime
  date_end         DateTime?
  cover_url        String?
  status_event     event_status    @default(PENDING)
  reason_rejection String?
  promoter         String // quem está a realizar o evento ou o nome da empresa
  promoter_nif     String // nif do promotor
  max_guests       Int? // número máximo de convidados para o evento
  purchased        Int             @default(0) // número de ingressos já vendidos para o evento
  duration         Int? // duração do evento em minutos
  contact          Json // contato para mais informações ["example@example.com", "123456789"]
  location         String
  province         String
  available        Boolean         @default(false)
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt
  classification   String?         @default("C") // A, B, C
  responsible_id   String? // O nosso funcionario responsável por este evento
  responsible      user?           @relation(fields: [responsible_id], references: [id])
  event_category   event_category? @relation(fields: [category], references: [name])
  images           image[]
  guests           guest[]
  packages         packages[]
  members          member[]
  tickets          ticket[]
  comments      comment[]
}

model comment {
  id         String   @id @default(uuid())
  event_id   String
  user_id    String
  content    String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  event      event    @relation(fields: [event_id], references: [id])
  user       user     @relation(fields: [user_id], references: [id])
}

model member {
  id         String     @id @default(uuid())
  user_id    String
  event_id   String
  name       String // nome do membro, para facilitar a identificação, por exemplo: João Silva
  user       user       @relation(fields: [user_id], references: [id])
  event      event      @relation(fields: [event_id], references: [id])
  permission permission @default(STAFF) // cargo do membro no evento, por exemplo: organizador, voluntário, etc.
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt
}

// adiconar categorias para os eventos, como por exemplo: música, teatro, conferência, etc. para facilitar a organização e busca dos eventos
model event_category {
  id         String   @id @default(uuid())
  name       String   @unique
  active     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  events event[]
}

model packages {
  id            String   @id @default(uuid())
  name          String
  benefits      Json     @default("[]") // benefícios do pacote, por exemplo: acesso VIP, open bar, etc.
  price         Float    @default(0)
  default_color String?
  event_id      String
  max_tickets   Int? // número máximo de ingressos disponíveis para este pacote
  purchased     Int      @default(0) // número de ingressos já vendidos para este pacote
  priority      Int      @default(0)
  event         event    @relation(fields: [event_id], references: [id])
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  tickets       ticket[]
}

model image {
  id         String   @id @default(uuid())
  url        String
  priority   Int      @default(0)
  event_id   String
  event      event    @relation(fields: [event_id], references: [id])
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model ticket {
  id            String   @id @default(uuid())
  package_id    String
  user_id       String
  package_name  String // nome do pacote, para facilitar a identificação por exemplo: VIP, Pista, etc.
  package_color String? // cor do pacote, para facilitar a identificação por exemplo: vermelho, azul, etc.
  name          String // nome do convidado, para facilitar a identificação por exemplo: João Silva
  qr_code       String?
  event_id      String
  is_used       Boolean  @default(false)
  is_paid       Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  package       packages @relation(fields: [package_id], references: [id])
  user          user     @relation(fields: [user_id], references: [id])
  event         event    @relation(fields: [event_id], references: [id])
}

model guest {
  id               String       @id @default(uuid())
  name             String
  email            String
  phone            String
  code_email       String? // código de confirmação para o evento
  expiration_email DateTime? // data de expiração do código de confirmação
  status           status_guest @default(PENDING)
  link             String?
  debt             Float        @default(0) // valor devido pelo convidado
  event_id         String
  event            event        @relation(fields: [event_id], references: [id])
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt
  payments         payment[]
}

model payment {
  id         String         @id @default(uuid())
  guest_id   String
  ref        String         @unique // referência do pagamento, por exemplo: número do boleto, id da transação, etc.
  amount     Float
  method     String // método de pagamento, por exemplo: cartão de crédito, boleto, etc.
  status     payment_status @default(PENDING) // status do pagamento, por exemplo: pendente, aprovado, recusado, etc.
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt

  guest guest @relation(fields: [guest_id], references: [id])
}

model notification {
  id         String    @id @default(uuid())
  user_id    String
  message    String
  read       Boolean   @default(false)
  read_at    DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  user       user      @relation(fields: [user_id], references: [id])
}

enum role {
  USER
  MANAGER
  ADMIN
}

enum status_guest {
  PENDING // fez a solicitacao
  APPROVED // aprovado para participar do evento
  REJECTED // rejeitado para participar do evento
  EXPIRED // expirou o prazo para confirmação do convite
  BLOCKED // bloqueado por algum motivo, não pode participar do evento
}

enum permission {
  MANAGER
  STAFF
}

enum payment_status {
  PENDING
  APPROVED
  REJECTED
}

enum event_status {
  PENDING
  ACTIVE
  BLOCKED
  REJECTED
  CANCELLED
  FINISH
}
